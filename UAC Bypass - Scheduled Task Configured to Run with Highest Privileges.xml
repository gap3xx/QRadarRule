<rule id="171439" enabled="true" buildingBlock="false" roleDefinition="false" type="EVENT" scope="LOCAL" owner="admin" overrideid="171439"><name>UAC Bypass - Scheduled Task Configured to Run with Highest Privileges</name><notes>This rule triggers when a scheduled task is configured to run with the highest privileges.</notes><testDefinitions><test id="14" name="com.q1labs.semsources.cre.tests.DeviceTypeID_Test" uid="0" group="Log Source Tests" requiredCapabilities="EventViewer.RULECREATION|SURVEILLANCE.RULECREATION"><text>when the event(s) were detected by one or more of &lt;a href='javascript:editParameter("0", "1")' class='dynamic'&gt;Microsoft Windows Security Event Log&lt;/a&gt;</text><parameter id="1"><initialText>these log source types</initialText><selectionLabel>Select a Log Source type and click 'Add'</selectionLabel><userOptions format="list" source="class" method="com.q1labs.sem.ui.semservices.UISemServices.getDeviceTypeDescs" multiselect="true"/><userSelection>12</userSelection><userSelectionTypes></userSelectionTypes><userSelectionId>0</userSelectionId></parameter></test><test id="19" name="com.q1labs.semsources.cre.tests.QID_Test" uid="1" group="Event Property Tests" requiredCapabilities="EventViewer.RULECREATION|SURVEILLANCE.RULECREATION"><text>when the event QID is one of the following &lt;a href='javascript:editParameter("1", "1")' class='dynamic'&gt;(5000872) Success Audit: A scheduled task was created, (5000876) Success Audit: A scheduled task was updated&lt;/a&gt;</text><parameter id="1"><initialText>QIDs</initialText><selectionLabel>Browse or Search for QIDs below. Select the desired QIDs and click 'Add'</selectionLabel><userOptions format="CustomizeParameter-QID.jsp" source="class" method="com.q1labs.sem.ui.semservices.UISemServices.getQidsByLowLevelCategory" multiselect="true"/><userSelection>5000872, 5000876</userSelection><userSelectionTypes></userSelectionTypes><userSelectionId>0</userSelectionId></parameter></test><test id="320" name="com.q1labs.semsources.cre.tests.AQL_Test" uid="2" group="Common Property Tests" requiredCapabilities="EventViewer.RULECREATION|SURVEILLANCE.RULECREATION"><text>when the event matches &lt;a href='javascript:editParameter("2", "1")' class='dynamic'&gt;RunLevel = 'HighestAvailable'&lt;/a&gt; AQL filter query</text><parameter id="1"><initialText>this</initialText><selectionLabel>Enter an AQL filter query</selectionLabel><userOptions format="CustomizeParameter-AQL.jsp" source="user"/><userSelection>RunLevel%20%3D%20'HighestAvailable'|%5B%22RunLevel%20%3D%20'HighestAvailable'%22%5D</userSelection><userSelectionTypes>property</userSelectionTypes><userSelectionId>0</userSelectionId></parameter><parameter id="2"><initialText></initialText><selectionLabel>Select a value</selectionLabel><userSelection>events</userSelection><userSelectionId>0</userSelectionId></parameter></test></testDefinitions><actions offenseMapping="0" forceOffenseCreation="true" includeAttackerEventsInterval="0" flowAnalysisInterval="0"><alterMetric metric="setSeverity" operation="setSeverity" value="6"/><alterMetric metric="setCredibility" operation="setCredibility" value="6"/><alterMetric metric="setRelevance" operation="setRelevance" value="6"/></actions><responses referenceMap="false" referenceMapOfSets="false" referenceMapOfMaps="false" referenceTable="false" referenceMapRemove="false" referenceMapOfSetsRemove="false" referenceMapOfMapsRemove="false" referenceTableRemove="false"><newevent name="Possible UAC Bypass - A Scheduled Task Has Been Configured to Run with Highest Privileges" description="Possible UAC Bypass - A Scheduled Task Has Been Configured to Run with Highest Privileges" severity="5" credibility="10" relevance="10" describeOffense="true" overrideOffenseName="false" contributeOffenseName="true" qid="67503557" forceOffenseCreation="true" offenseMapping="0" lowLevelCategory="7023"/></responses></rule>